{
  "name": "@hasoftware/devradar",
  "version": "1.1.0",
  "description": "A CLI tool to analyze code projects: count lines of code, detect programming languages, and identify frameworks in use.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "devradar": "./bin/devradar.js"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/devradar.js",
    "test": "node --test test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cli",
    "code-analysis",
    "loc",
    "line-counter",
    "language-detection",
    "framework-detection",
    "monorepo",
    "devradar",
    "hasoftware"
  ],
  "author": "HASOFTWARE",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/hasoftware/DevRadar",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasoftware/DevRadar.git"
  },
  "bugs": {
    "url": "https://github.com/hasoftware/DevRadar/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "cross-spawn": "^7.0.6",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "ora": "^8.1.0"
  }
}
